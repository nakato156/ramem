# Required: accept the Gemma license on Hugging Face, then paste a read token.
HF_TOKEN=

# Hugging Face data/model caches. Use a persistent Studio path in Lightning.
HF_HOME=.cache/huggingface
HF_DATASETS_CACHE=.cache/huggingface/datasets
TOKENIZERS_PARALLELISM=true

# RaMem paths. Relative paths are resolved from the repository root.
RAMEM_CONFIG=configs/default.yaml
RAMEM_RAW_DATA_DIR=data/raw
RAMEM_PROCESSED_DATA_DIR=data/processed
RAMEM_ARTIFACTS_DIR=artifacts
RAMEM_TRAIN_CONFIG=configs/training/gemma_1b_t4_qlora.yaml

# Runtime defaults for a single-GPU Lightning Studio.
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# uv may cross filesystems in Lightning; copying avoids hard-link warnings/failures.
UV_LINK_MODE=copy

# Optional privacy/noise controls.
HF_HUB_DISABLE_TELEMETRY=1
DO_NOT_TRACK=1
